{
  "name": "debt-recycler-au",
  "version": "0.1.0",
  "description": "Debt recycling calculator for Australian property investors",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src tests",
    "format": "prettier --write src tests",
    "migrate": "node scripts/migrate.js",
    "verify:production": "node tests/auth_production.js",
    "verify:dashboard": "node tests/dashboard_ui_production.js",
    "verify:scenarios": "node tests/scenarios_ui_production.js",
    "verify:client_portal": "node tests/client_portal_production.js",
    "verify:report_generation_ui": "node tests/report_generation_ui_production.js",
    "verify:excel_export_ui": "node tests/excel_export_ui_production.js",
    "verify:email_ui": "node tests/email_ui_production.js",
    "verify:billing_ui": "node tests/billing_ui_production.js",
    "verify:tier_enforcement_ui": "node tests/tier_enforcement_ui_production.js",
    "verify:scenario_versioning_ui": "node tests/scenario_versioning_ui_production.js"
  },
  "keywords": [
    "debt-recycling",
    "property-investment",
    "australia"
  ],
  "author": "Rahul Gurjar",
  "license": "MIT",
  "dependencies": {
    "aws-sdk": "^2.1633.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^6.9.0",
    "pdfkit": "^0.13.0",
    "pg": "^8.11.0",
    "serverless-http": "^3.2.0",
    "stripe": "^11.18.0"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFiles": ["<rootDir>/tests/setup.js"],
    "moduleNameMapper": {
      "^pg$": "<rootDir>/tests/__mocks__/pg.js"
    },
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/src/node_modules/",
      "/client/"
    ]
  },
  "devDependencies": {
    "eslint": "^8.50.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "pg-mem": "^3.0.14",
    "prettier": "^3.0.3",
    "puppeteer": "^24.40.0",
    "supertest": "^6.3.4"
  }
}
